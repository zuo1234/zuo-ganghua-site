<%= form_with model: [:admin, post], class: "post-form" do |form| %>
  <% if post.errors.any? %>
    <div class="form-errors">
      <strong><%= pluralize(post.errors.count, "error") %> prevented this post from saving:</strong>
      <ul>
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-grid">
    <label>
      <span>Title</span>
      <%= form.text_field :title, required: true %>
    </label>

    <label>
      <span>Slug</span>
      <%= form.text_field :slug, placeholder: "auto-generated-from-title" %>
    </label>
  </div>

  <label>
    <span>Excerpt</span>
    <%= form.text_area :excerpt, rows: 3 %>
  </label>

  <div class="form-field rich-text-field" data-controller="rich-text">
    <span class="field-label" id="post-body-label">Body</span>
    <div class="rich-text-toolbar" aria-label="富文本工具栏">
      <button type="button" title="正文" data-action="rich-text#format" data-rich-text-command-param="formatBlock" data-rich-text-value-param="p">P</button>
      <button type="button" title="二级标题" data-action="rich-text#format" data-rich-text-command-param="formatBlock" data-rich-text-value-param="h2">H2</button>
      <button type="button" title="三级标题" data-action="rich-text#format" data-rich-text-command-param="formatBlock" data-rich-text-value-param="h3">H3</button>
      <button type="button" title="加粗" data-action="rich-text#format" data-rich-text-command-param="bold">B</button>
      <button type="button" title="斜体" data-action="rich-text#format" data-rich-text-command-param="italic">I</button>
      <button type="button" title="下划线" data-action="rich-text#format" data-rich-text-command-param="underline">U</button>
      <button type="button" title="引用" data-action="rich-text#format" data-rich-text-command-param="formatBlock" data-rich-text-value-param="blockquote">Quote</button>
      <button type="button" title="无序列表" data-action="rich-text#format" data-rich-text-command-param="insertUnorderedList">List</button>
      <button type="button" title="有序列表" data-action="rich-text#format" data-rich-text-command-param="insertOrderedList">1. List</button>
      <button type="button" title="代码块" data-action="rich-text#format" data-rich-text-command-param="formatBlock" data-rich-text-value-param="pre">Code</button>
      <button type="button" title="链接" data-action="rich-text#link">Link</button>
      <button type="button" title="上传图片" data-action="rich-text#chooseImage">Image</button>
      <button type="button" title="小图" data-action="rich-text#setImageSize" data-rich-text-size-param="small">Small</button>
      <button type="button" title="中图" data-action="rich-text#setImageSize" data-rich-text-size-param="medium">Medium</button>
      <button type="button" title="全宽图" data-action="rich-text#setImageSize" data-rich-text-size-param="full">Full</button>
      <button type="button" title="清除格式" data-action="rich-text#clear">Clear</button>
    </div>
    <input
      type="file"
      class="rich-text-file-input"
      accept="image/*"
      data-rich-text-target="fileInput"
      data-action="change->rich-text#uploadImage"
    >
    <div
      class="rich-text-editor"
      contenteditable="true"
      role="textbox"
      aria-multiline="true"
      aria-labelledby="post-body-label"
      data-placeholder="写下正文..."
      data-rich-text-target="editor"
      data-action="input->rich-text#sync blur->rich-text#sync paste->rich-text#handlePaste"
    ></div>
    <span class="rich-text-status" data-rich-text-target="status" aria-live="polite"></span>
    <%= form.hidden_field :body, required: true, data: { rich_text_target: "input" } %>
  </div>

  <div class="form-grid">
    <label>
      <span>Status</span>
      <%= form.select :status, Post::STATUSES.map { |status| [status.titleize, status] } %>
    </label>

    <label>
      <span>Tag</span>
      <%= form.select :tag, Post.tag_options %>
    </label>
  </div>

  <div class="form-grid">
    <label>
      <span>Published at</span>
      <%= form.datetime_local_field :published_at %>
    </label>
  </div>

  <div class="form-actions">
    <%= button_tag "Save draft", type: "submit", name: "commit_action", value: "draft", class: "admin-button" %>
    <%= button_tag "Save and preview", type: "submit", name: "commit_action", value: "preview", class: "admin-button" %>
    <%= button_tag "Publish", type: "submit", name: "commit_action", value: "publish", class: "admin-button admin-button--primary" %>
  </div>
<% end %>
