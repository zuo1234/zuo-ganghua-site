<% content_for :title, "Ask Zuogh - 左刚华" %>

<main
  class="site-main content-page tools-page chat-page"
  data-controller="ai-chat"
  data-ai-chat-endpoint-value="<%= chat_messages_path %>"
>
  <nav class="tools-nav" aria-label="页面导航">
    <%= link_to "ZUOGH", root_path, class: "tools-nav__brand" %>

    <div class="tools-nav__links">
      <%= link_to "/about", root_path(anchor: "intro-title") %>
      <%= link_to "/projects", root_path(anchor: "projects") %>
      <%= link_to "/journal", posts_path %>
      <%= link_to "/tools", tools_path %>
      <%= link_to "/ai", chat_path, class: "is-active" %>
      <%= link_to "/contact", "mailto:hello@example.com" %>
    </div>
  </nav>

  <header class="tools-hero chat-hero" aria-labelledby="chat-title">
    <div>
      <p class="eyebrow tools-hero__eyebrow">/chat</p>
      <h1 id="chat-title">Ask Zuogh</h1>
      <p class="tools-hero__subtitle">关于后端工程、写作和这个站点。</p>
    </div>

    <p class="tools-status">AI 生成内容仅供参考。</p>
  </header>

  <section class="chat-shell" aria-label="AI 对话">
    <div class="chat-stream" data-ai-chat-target="messages" aria-live="polite" aria-relevant="additions">
      <article class="chat-message chat-message--assistant">
        <span class="chat-message__role">ZUOGH AI</span>
        <p class="chat-message__body">你好，想从哪里开始？</p>
      </article>
    </div>

    <form class="chat-composer" data-ai-chat-target="form" data-action="submit->ai-chat#send">
      <label class="visually-hidden" for="ai-chat-input">输入消息</label>
      <textarea
        id="ai-chat-input"
        class="chat-composer__input"
        name="message"
        rows="3"
        maxlength="4000"
        placeholder="输入你的问题..."
        data-ai-chat-target="input"
        data-action="keydown->ai-chat#handleKeydown"
      ></textarea>

      <div class="chat-composer__footer">
        <p class="chat-status" data-ai-chat-target="status" role="status">准备就绪</p>
        <button class="chat-send-button" type="submit" data-ai-chat-target="sendButton">Send</button>
      </div>
    </form>
  </section>
</main>

<footer class="site-footer site-footer--compact">
  <nav class="footer-links" aria-label="页脚链接">
    <%= link_to "Home", root_path %>
    <%= link_to "Writing", posts_path %>
    <%= link_to "Photos", photos_path %>
    <%= link_to "Tools", tools_path %>
    <%= link_to "AI Chat", chat_path %>
    <%= link_to "Email", "mailto:hello@example.com" %>
  </nav>
</footer>
