<!DOCTYPE html>
<html lang="zh-CN" data-controller="theme" data-theme-dark-class="dark">
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "左刚华 - 个人站" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="左刚华的个人主页，记录后端工程、软件开发、写作、项目与相册。">
    <meta property="og:title" content="左刚华 - 软件工程师">
    <meta property="og:description" content="关注 Ruby、Rails、Golang、后端系统设计和可维护的软件工程实践。">
    <meta property="og:type" content="website">
    <meta property="og:image" content="<%= asset_url("avatar.png") %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700;800&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application" %>
    <%= javascript_include_tag "application", type: "module", defer: true %>
  </head>

  <body>
    <button
      class="theme-toggle"
      type="button"
      aria-label="切换深浅色主题"
      title="切换深浅色主题"
      data-action="click->theme#toggle"
    >
      <span class="theme-toggle__icon" aria-hidden="true"></span>
    </button>

    <%= yield %>
  </body>
</html>
