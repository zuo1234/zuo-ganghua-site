import { Application, Controller } from "<%= asset_path "stimulus.min.js" %>"

class ThemeController extends Controller {
  static classes = ["dark"]

  connect() {
    const storedTheme = localStorage.getItem("theme")
    const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches

    this.setDark(storedTheme === "dark" || (!storedTheme && prefersDark))
  }

  toggle() {
    const nextDark = !this.element.classList.contains(this.darkClass)

    this.setDark(nextDark)
    localStorage.setItem("theme", nextDark ? "dark" : "light")
  }

  setDark(enabled) {
    this.element.classList.toggle(this.darkClass, enabled)
  }
}

class ArcadeController extends Controller {
  static targets = ["tab", "title", "status", "score", "screen", "help"]
  static values = {
    initialGame: { type: String, default: "path" }
  }

  static rubordleWords = [
    "RAILS",
    "MODEL",
    "ROUTE",
    "SCOPE",
    "YIELD",
    "BLOCK",
    "PARAM",
    "CACHE",
    "QUEUE",
    "TURBO",
    "VALID",
    "FLASH"
  ]

  static sudokuPuzzles = [
    {
      puzzle: "530070000600195000098000060800060003400803001700020006060000280000419005000080079",
      solution: "534678912672195348198342567859761423426853791713924856961537284287419635345286179"
    },
    {
      puzzle: "000260701680070090190004500820100040004602900050003028009300074040050036703018000",
      solution: "435269781682571493197834562826195347374682915951743628519326874248957136763418259"
    }
  ]

  connect() {
    this.game = this.initialGameValue
    this.score = 0
    this.running = false
    this.pathPosition = { x: 0, y: 0 }
    this.pathFiles = []
    this.pathTraps = []
    this.scanSequence = []
    this.scanInput = []
    this.logRound = null
    this.rubordleGuesses = []
    this.rubordleCurrent = ""
    this.rubordleAnswer = this.rubordleDailyWord()
    this.rubordleComplete = false
    this.sudokuPuzzle = this.sudokuDailyPuzzle()
    this.sudokuBoard = this.sudokuPuzzle.puzzle.split("")
    this.sudokuSelected = 0
    this.sudokuErrors = new Set()
    this.sudokuComplete = false

    this.boundKeydown = this.handleKeydown.bind(this)
    document.addEventListener("keydown", this.boundKeydown)
    this.render()
  }

  disconnect() {
    document.removeEventListener("keydown", this.boundKeydown)
  }

  selectGame(event) {
    this.game = event.currentTarget.dataset.game
    this.reset()
  }

  start() {
    this.running = true
    this.score = 0

    if (this.game === "path") this.startPath()
    if (this.game === "scan") this.startScan()
    if (this.game === "logs") this.startLogs()
    if (this.game === "rubordle") this.startRubordle()
    if (this.game === "sudoku") this.startSudoku()
  }

  reset() {
    this.running = false
    this.score = 0
    this.scanSequence = []
    this.scanInput = []
    this.logRound = null
    this.rubordleGuesses = []
    this.rubordleCurrent = ""
    this.rubordleAnswer = this.rubordleDailyWord()
    this.rubordleComplete = false
    this.sudokuPuzzle = this.sudokuDailyPuzzle()
    this.sudokuBoard = this.sudokuPuzzle.puzzle.split("")
    this.sudokuSelected = 0
    this.sudokuErrors = new Set()
    this.sudokuComplete = false
    this.render()
  }

  handleKeydown(event) {
    if (!this.running) return

    if (this.game === "path") this.handlePathKey(event)
    if (this.game === "scan") this.handleScanKey(event)
    if (this.game === "logs") this.handleLogKey(event)
    if (this.game === "rubordle") this.handleRubordleKey(event)
    if (this.game === "sudoku") this.handleSudokuKey(event)
  }

  startPath() {
    this.pathPosition = { x: 0, y: 0 }
    this.pathFiles = [
      { x: 2, y: 1 },
      { x: 5, y: 2 },
      { x: 1, y: 4 },
      { x: 6, y: 5 }
    ]
    this.pathTraps = [
      { x: 3, y: 0 },
      { x: 4, y: 3 },
      { x: 2, y: 5 }
    ]
    this.render()
    this.screenTarget.focus()
  }

  handlePathKey(event) {
    const moves = {
      ArrowUp: [0, -1],
      ArrowRight: [1, 0],
      ArrowDown: [0, 1],
      ArrowLeft: [-1, 0],
      w: [0, -1],
      d: [1, 0],
      s: [0, 1],
      a: [-1, 0]
    }
    const move = moves[event.key]
    if (!move) return

    event.preventDefault()
    const next = {
      x: Math.max(0, Math.min(6, this.pathPosition.x + move[0])),
      y: Math.max(0, Math.min(5, this.pathPosition.y + move[1]))
    }

    this.pathPosition = next
    const fileIndex = this.pathFiles.findIndex((file) => file.x === next.x && file.y === next.y)
    if (fileIndex >= 0) {
      this.pathFiles.splice(fileIndex, 1)
      this.score += 25
    }

    const hitTrap = this.pathTraps.some((trap) => trap.x === next.x && trap.y === next.y)
    if (hitTrap) {
      this.score = Math.max(0, this.score - 15)
      this.statusTarget.textContent = "permission denied"
    }

    if (this.pathFiles.length === 0) {
      this.running = false
      this.score += 50
      this.renderPath("deploy complete")
      return
    }

    this.renderPath(hitTrap ? "trap hit" : "collect all files")
  }

  startScan() {
    this.scanSequence = this.randomPorts(4)
    this.scanInput = []
    this.renderScan("memorize the open ports")
    this.screenTarget.focus()
  }

  handleScanKey(event) {
    if (!/^[1-4]$/.test(event.key)) return

    event.preventDefault()
    this.scanInput.push(Number(event.key))

    const index = this.scanInput.length - 1
    if (this.scanInput[index] !== this.scanSequence[index]) {
      this.running = false
      this.renderScan("scan failed")
      return
    }

    if (this.scanInput.length === this.scanSequence.length) {
      this.score += this.scanSequence.length * 20
      this.scanSequence = this.randomPorts(Math.min(8, this.scanSequence.length + 1))
      this.scanInput = []
      this.renderScan("next sequence")
      return
    }

    this.renderScan("keep going")
  }

  startLogs() {
    this.nextLogRound("classify the log")
    this.screenTarget.focus()
  }

  handleLogKey(event) {
    const keyMap = {
      e: "error",
      w: "warn",
      i: "info"
    }
    const answer = keyMap[event.key.toLowerCase()]
    if (!answer || !this.logRound) return

    event.preventDefault()
    if (answer === this.logRound.kind) {
      this.score += 15
      this.nextLogRound("accepted")
    } else {
      this.score = Math.max(0, this.score - 10)
      this.nextLogRound("wrong bucket")
    }
  }

  render() {
    this.updateTabs()
    this.scoreTarget.textContent = this.score

    if (this.game === "path") this.renderPath("ready")
    if (this.game === "scan") this.renderScan("ready")
    if (this.game === "logs") this.renderLogs("ready")
    if (this.game === "rubordle") this.renderRubordle("ready")
    if (this.game === "sudoku") this.renderSudoku("ready")
  }

  updateTabs() {
    this.tabTargets.forEach((tab) => {
      tab.classList.toggle("is-active", tab.dataset.game === this.game)
    })
  }

  renderPath(message) {
    this.titleTarget.textContent = "PATHFIND"
    this.statusTarget.textContent = message
    this.scoreTarget.textContent = this.score
    this.helpTarget.innerHTML = `
      <h3>PATHFIND</h3>
      <p>在小型文件系统里移动光标，收集所有 <code>file</code>，避开 <code>root</code> 陷阱。</p>
      <dl>
        <dt>Move</dt><dd>Arrow keys / WASD</dd>
        <dt>Goal</dt><dd>收集 4 个文件</dd>
      </dl>
    `

    const rows = []
    for (let y = 0; y < 6; y += 1) {
      const cells = []
      for (let x = 0; x < 7; x += 1) {
        if (this.pathPosition.x === x && this.pathPosition.y === y) {
          cells.push("<span class=\"terminal-cell terminal-cell--player\">@</span>")
        } else if (this.pathFiles.some((file) => file.x === x && file.y === y)) {
          cells.push("<span class=\"terminal-cell terminal-cell--file\">*</span>")
        } else if (this.pathTraps.some((trap) => trap.x === x && trap.y === y)) {
          cells.push("<span class=\"terminal-cell terminal-cell--trap\">#</span>")
        } else {
          cells.push("<span class=\"terminal-cell\">.</span>")
        }
      }
      rows.push(`<div class="terminal-grid__row">${cells.join("")}</div>`)
    }

    this.screenTarget.innerHTML = `
      <div class="terminal-log">$ ./pathfind --collect ./files</div>
      <div class="terminal-grid">${rows.join("")}</div>
      <div class="terminal-legend">
        <span>@ you</span><span>* file</span><span># root trap</span>
      </div>
    `
  }

  renderScan(message) {
    this.titleTarget.textContent = "PORT SCAN"
    this.statusTarget.textContent = message
    this.scoreTarget.textContent = this.score
    this.helpTarget.innerHTML = `
      <h3>PORT SCAN</h3>
      <p>记住高亮端口顺序，然后用数字键复现。每轮序列都会变长。</p>
      <dl>
        <dt>Input</dt><dd>数字键 1 / 2 / 3 / 4</dd>
        <dt>Goal</dt><dd>尽可能通过更多轮扫描</dd>
      </dl>
    `

    const ports = [1, 2, 3, 4].map((port) => {
      const activeIndex = this.scanSequence.indexOf(port)
      const submitted = this.scanInput.includes(port)
      const label = ["ssh:22", "http:80", "db:5432", "redis:6379"][port - 1]
      return `
        <button type="button" class="port-node ${activeIndex >= 0 ? "is-open" : ""} ${submitted ? "is-submitted" : ""}">
          <span>${port}</span>
          ${label}
        </button>
      `
    })

    this.screenTarget.innerHTML = `
      <div class="terminal-log">$ nmap --sequence localhost</div>
      <div class="scan-sequence">open sequence: ${this.scanSequence.join(" ") || "run to generate"}</div>
      <div class="port-grid">${ports.join("")}</div>
      <div class="terminal-log">input: ${this.scanInput.join(" ") || "_"}</div>
    `
  }

  renderLogs(message) {
    this.titleTarget.textContent = "LOG PARSER"
    this.statusTarget.textContent = message
    this.scoreTarget.textContent = this.score
    this.helpTarget.innerHTML = `
      <h3>LOG PARSER</h3>
      <p>读取当前日志行，并把它分到正确级别。连续判断会不断刷新日志。</p>
      <dl>
        <dt>Error</dt><dd>E</dd>
        <dt>Warn</dt><dd>W</dd>
        <dt>Info</dt><dd>I</dd>
      </dl>
    `

    const round = this.logRound || {
      kind: "info",
      line: "INFO  boot sequence waiting for run command"
    }

    this.screenTarget.innerHTML = `
      <div class="terminal-log">$ tail -f production.log</div>
      <div class="log-line log-line--${round.kind}">${round.line}</div>
      <div class="log-actions">
        <button type="button" data-key="e">E error</button>
        <button type="button" data-key="w">W warn</button>
        <button type="button" data-key="i">I info</button>
      </div>
      <div class="terminal-log">Press E / W / I</div>
    `

    this.screenTarget.querySelectorAll(".log-actions button").forEach((button) => {
      button.addEventListener("click", () => {
        this.handleLogKey({ key: button.dataset.key, preventDefault() {} })
      })
    })
  }

  nextLogRound(message) {
    const rounds = [
      { kind: "error", line: "ERROR payment_job failed: retry budget exhausted" },
      { kind: "warn", line: "WARN cache miss rate above 35% for /projects" },
      { kind: "info", line: "INFO deploy finished in 42s with 0 failed checks" },
      { kind: "warn", line: "WARN memory pressure detected on worker-02" },
      { kind: "error", line: "ERROR ActionView::Template::Error missing avatar.png" },
      { kind: "info", line: "INFO user opened terminal arcade session" }
    ]
    this.logRound = rounds[Math.floor(Math.random() * rounds.length)]
    this.renderLogs(message)
  }

  randomPorts(length) {
    return Array.from({ length }, () => Math.floor(Math.random() * 4) + 1)
  }

  startRubordle() {
    this.rubordleGuesses = []
    this.rubordleCurrent = ""
    this.rubordleAnswer = this.rubordleDailyWord()
    this.rubordleComplete = false
    this.renderRubordle("guess the keyword")
    this.screenTarget.focus()
  }

  handleRubordleKey(event) {
    if (this.rubordleComplete) return

    const key = event.key
    const letter = key.toUpperCase()
    if (/^[A-Z]$/.test(letter)) {
      event.preventDefault()
      if (this.rubordleCurrent.length < 5) {
        this.rubordleCurrent += letter
        this.renderRubordle("typing")
      }
      return
    }

    if (key === "Backspace") {
      event.preventDefault()
      this.rubordleCurrent = this.rubordleCurrent.slice(0, -1)
      this.renderRubordle("typing")
      return
    }

    if (key === "Enter") {
      event.preventDefault()
      this.submitRubordleGuess()
    }
  }

  pressRubordleKey(event) {
    this.handleRubordleKey({
      key: event.currentTarget.dataset.key,
      preventDefault() {}
    })
  }

  submitRubordleGuess() {
    if (this.rubordleCurrent.length !== 5) {
      this.renderRubordle("need 5 letters")
      return
    }

    this.rubordleGuesses.push(this.rubordleCurrent)
    if (this.rubordleCurrent === this.rubordleAnswer) {
      this.rubordleComplete = true
      this.score += 120 - (this.rubordleGuesses.length - 1) * 15
      this.renderRubordle("bundle green")
      return
    }

    this.rubordleCurrent = ""
    if (this.rubordleGuesses.length >= 6) {
      this.rubordleComplete = true
      this.renderRubordle(`answer: ${this.rubordleAnswer}`)
      return
    }

    this.renderRubordle("try again")
  }

  renderRubordle(message) {
    this.titleTarget.textContent = "RUBORDLE"
    this.statusTarget.textContent = message
    this.scoreTarget.textContent = this.score
    this.helpTarget.innerHTML = `
      <h3>RUBORDLE</h3>
      <p>猜一个 5 字母 Ruby/Rails 关键词。每次提交后，方块会显示位置反馈。</p>
      <dl>
        <dt>Green</dt><dd>字母和位置都正确</dd>
        <dt>Yellow</dt><dd>字母存在但位置不对</dd>
        <dt>Gray</dt><dd>答案里没有这个字母</dd>
      </dl>
    `

    this.screenTarget.innerHTML = `
      <div class="terminal-log">$ rubordle --daily --tries=6</div>
      <div class="rubordle-board">${this.rubordleRows()}</div>
      <div class="rubordle-keyboard">${this.rubordleKeyboard()}</div>
      <div class="terminal-log">Enter submit · Backspace delete · ${this.rubordleComplete ? `answer ${this.rubordleAnswer}` : "daily Ruby/Rails word"}</div>
    `

    this.screenTarget.querySelectorAll("[data-key]").forEach((button) => {
      button.addEventListener("click", (event) => this.pressRubordleKey(event))
    })
  }

  rubordleRows() {
    const rows = []
    for (let row = 0; row < 6; row += 1) {
      const guess = this.rubordleGuesses[row]
      const letters = guess || (row === this.rubordleGuesses.length ? this.rubordleCurrent : "")
      const states = guess ? this.scoreRubordleGuess(guess) : []
      const cells = []

      for (let index = 0; index < 5; index += 1) {
        const letter = letters[index] || ""
        const state = states[index] || "empty"
        cells.push(`<span class="rubordle-tile rubordle-tile--${state}">${letter}</span>`)
      }

      rows.push(`<div class="rubordle-row">${cells.join("")}</div>`)
    }

    return rows.join("")
  }

  rubordleKeyboard() {
    const rows = ["QWERTYUIOP", "ASDFGHJKL", "ZXCVBNM"]
    const stateByLetter = this.rubordleLetterStates()
    const keyboardRows = rows.map((row) => {
      const keys = row.split("").map((letter) => {
        const state = stateByLetter[letter] || "unused"
        return `<button type="button" class="rubordle-key rubordle-key--${state}" data-key="${letter}">${letter}</button>`
      })

      return `<div class="rubordle-key-row">${keys.join("")}</div>`
    })

    keyboardRows.push(`
      <div class="rubordle-key-row">
        <button type="button" class="rubordle-key rubordle-key--wide" data-key="Enter">Enter</button>
        <button type="button" class="rubordle-key rubordle-key--wide" data-key="Backspace">Delete</button>
      </div>
    `)

    return keyboardRows.join("")
  }

  scoreRubordleGuess(guess) {
    const answer = this.rubordleAnswer.split("")
    const result = Array(5).fill("absent")
    const remaining = {}

    answer.forEach((letter, index) => {
      if (guess[index] === letter) {
        result[index] = "correct"
      } else {
        remaining[letter] = (remaining[letter] || 0) + 1
      }
    })

    guess.split("").forEach((letter, index) => {
      if (result[index] === "correct") return
      if (remaining[letter] > 0) {
        result[index] = "present"
        remaining[letter] -= 1
      }
    })

    return result
  }

  rubordleLetterStates() {
    const priority = {
      unused: 0,
      absent: 1,
      present: 2,
      correct: 3
    }
    const states = {}

    this.rubordleGuesses.forEach((guess) => {
      this.scoreRubordleGuess(guess).forEach((state, index) => {
        const letter = guess[index]
        const current = states[letter] || "unused"
        if (priority[state] > priority[current]) states[letter] = state
      })
    })

    return states
  }

  rubordleDailyWord() {
    const start = new Date("2026-01-01T00:00:00Z")
    const today = new Date()
    const day = Math.floor((Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()) - start.getTime()) / 86400000)
    const words = this.constructor.rubordleWords

    return words[((day % words.length) + words.length) % words.length]
  }

  startSudoku() {
    this.sudokuPuzzle = this.sudokuDailyPuzzle()
    this.sudokuBoard = this.sudokuPuzzle.puzzle.split("")
    this.sudokuSelected = this.sudokuBoard.findIndex((value) => value === "0")
    if (this.sudokuSelected < 0) this.sudokuSelected = 0
    this.sudokuErrors = new Set()
    this.sudokuComplete = false
    this.renderSudoku("fill the grid")
    this.screenTarget.focus()
  }

  handleSudokuKey(event) {
    if (this.sudokuComplete) return

    const moves = {
      ArrowUp: -9,
      ArrowRight: 1,
      ArrowDown: 9,
      ArrowLeft: -1
    }

    if (event.key in moves) {
      event.preventDefault()
      this.moveSudokuSelection(moves[event.key])
      return
    }

    if (/^[1-9]$/.test(event.key)) {
      event.preventDefault()
      this.fillSudokuCell(event.key)
      return
    }

    if (event.key === "Backspace" || event.key === "Delete" || event.key === "0") {
      event.preventDefault()
      this.clearSudokuCell()
    }
  }

  selectSudokuCell(event) {
    this.sudokuSelected = Number(event.currentTarget.dataset.index)
    this.renderSudoku("cell selected")
    this.screenTarget.focus()
  }

  pressSudokuNumber(event) {
    if (!this.running || this.sudokuComplete) return

    const value = event.currentTarget.dataset.value
    if (value === "clear") {
      this.clearSudokuCell()
    } else {
      this.fillSudokuCell(value)
    }
    this.screenTarget.focus()
  }

  fillSudokuCell(value) {
    if (this.sudokuPuzzle.puzzle[this.sudokuSelected] !== "0") {
      this.renderSudoku("given cell")
      return
    }

    if (this.sudokuBoard[this.sudokuSelected] === value) {
      this.renderSudoku("already set")
      return
    }

    this.sudokuBoard[this.sudokuSelected] = value
    this.score = Math.max(0, this.score + (value === this.sudokuPuzzle.solution[this.sudokuSelected] ? 5 : -3))
    this.updateSudokuErrors()

    if (this.sudokuBoard.join("") === this.sudokuPuzzle.solution) {
      this.sudokuComplete = true
      this.score += 180
      this.renderSudoku("grid solved")
      return
    }

    this.renderSudoku(this.sudokuErrors.size > 0 ? "conflict found" : "keep solving")
  }

  clearSudokuCell() {
    if (this.sudokuPuzzle.puzzle[this.sudokuSelected] !== "0") {
      this.renderSudoku("given cell")
      return
    }

    this.sudokuBoard[this.sudokuSelected] = "0"
    this.updateSudokuErrors()
    this.renderSudoku("cell cleared")
  }

  moveSudokuSelection(delta) {
    const currentRow = Math.floor(this.sudokuSelected / 9)
    const currentCol = this.sudokuSelected % 9
    let next = this.sudokuSelected + delta

    if (delta === 1 && currentCol === 8) next = this.sudokuSelected - 8
    if (delta === -1 && currentCol === 0) next = this.sudokuSelected + 8
    if (delta === 9 && currentRow === 8) next = currentCol
    if (delta === -9 && currentRow === 0) next = 72 + currentCol

    this.sudokuSelected = Math.max(0, Math.min(80, next))
    this.renderSudoku("cell selected")
  }

  updateSudokuErrors() {
    this.sudokuErrors = new Set()
    this.sudokuBoard.forEach((value, index) => {
      if (value !== "0" && value !== this.sudokuPuzzle.solution[index]) {
        this.sudokuErrors.add(index)
      }
    })
  }

  renderSudoku(message) {
    this.titleTarget.textContent = "SUDOKU"
    this.statusTarget.textContent = message
    this.scoreTarget.textContent = this.score
    this.helpTarget.innerHTML = `
      <h3>SUDOKU</h3>
      <p>填满 9x9 数独。亮绿色是题目给定数字，蓝色是相同数字提示，粉色表示当前输入和答案冲突。</p>
      <dl>
        <dt>Move</dt><dd>方向键或点击格子</dd>
        <dt>Input</dt><dd>数字键 1-9</dd>
        <dt>Clear</dt><dd>Backspace / Delete / 0</dd>
      </dl>
    `

    this.screenTarget.innerHTML = `
      <div class="terminal-log">$ sudoku --daily --validate</div>
      <div class="sudoku-board">${this.sudokuCells()}</div>
      <div class="sudoku-keypad">${this.sudokuKeypad()}</div>
      <div class="terminal-log">${this.sudokuErrors.size} conflicts · ${this.sudokuEmptyCount()} empty cells</div>
    `

    this.screenTarget.querySelectorAll("[data-index]").forEach((button) => {
      button.addEventListener("click", (event) => this.selectSudokuCell(event))
    })
    this.screenTarget.querySelectorAll("[data-value]").forEach((button) => {
      button.addEventListener("click", (event) => this.pressSudokuNumber(event))
    })
  }

  sudokuCells() {
    return this.sudokuBoard.map((value, index) => {
      const given = this.sudokuPuzzle.puzzle[index] !== "0"
      const selected = index === this.sudokuSelected
      const sameValue = value !== "0" && value === this.sudokuBoard[this.sudokuSelected]
      const error = this.sudokuErrors.has(index)
      const boxEndCol = index % 3 === 2 && index % 9 !== 8
      const boxEndRow = Math.floor(index / 9) % 3 === 2 && index < 72
      const classes = [
        "sudoku-cell",
        given ? "sudoku-cell--given" : "",
        selected ? "is-selected" : "",
        sameValue ? "is-related" : "",
        error ? "is-error" : "",
        boxEndCol ? "sudoku-cell--box-end-col" : "",
        boxEndRow ? "sudoku-cell--box-end-row" : ""
      ].filter(Boolean).join(" ")

      return `<button type="button" class="${classes}" data-index="${index}">${value === "0" ? "" : value}</button>`
    }).join("")
  }

  sudokuKeypad() {
    const buttons = Array.from({ length: 9 }, (_, index) => {
      const value = String(index + 1)
      return `<button type="button" data-value="${value}">${value}</button>`
    })

    buttons.push("<button type=\"button\" data-value=\"clear\">Clear</button>")
    return buttons.join("")
  }

  sudokuEmptyCount() {
    return this.sudokuBoard.filter((value) => value === "0").length
  }

  sudokuDailyPuzzle() {
    const start = new Date("2026-01-01T00:00:00Z")
    const today = new Date()
    const day = Math.floor((Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()) - start.getTime()) / 86400000)
    const puzzles = this.constructor.sudokuPuzzles

    return puzzles[((day % puzzles.length) + puzzles.length) % puzzles.length]
  }
}

class GalleryController extends Controller {
  static targets = ["lightbox", "image", "title", "meta"]

  connect() {
    this.items = []
    this.currentIndex = 0
    this.boundKeydown = this.handleKeydown.bind(this)
    this.refreshItems()
  }

  disconnect() {
    document.removeEventListener("keydown", this.boundKeydown)
  }

  open(event) {
    this.refreshItems()
    this.currentIndex = Number(event.params.index || 0)
    this.render()
    this.lightboxTarget.classList.add("is-open")
    this.lightboxTarget.setAttribute("aria-hidden", "false")
    document.addEventListener("keydown", this.boundKeydown)
  }

  close() {
    this.lightboxTarget.classList.remove("is-open")
    this.lightboxTarget.setAttribute("aria-hidden", "true")
    document.removeEventListener("keydown", this.boundKeydown)
  }

  previous() {
    if (this.items.length === 0) return

    this.currentIndex = (this.currentIndex - 1 + this.items.length) % this.items.length
    this.render()
  }

  next() {
    if (this.items.length === 0) return

    this.currentIndex = (this.currentIndex + 1) % this.items.length
    this.render()
  }

  handleKeydown(event) {
    if (event.key === "Escape") this.close()
    if (event.key === "ArrowLeft") this.previous()
    if (event.key === "ArrowRight") this.next()
  }

  refreshItems() {
    this.items = Array.from(this.element.querySelectorAll("[data-gallery-url-param]")).map((item) => ({
      title: item.dataset.galleryTitleParam || "",
      url: item.dataset.galleryUrlParam || "",
      meta: item.dataset.galleryMetaParam || ""
    }))
  }

  render() {
    const item = this.items[this.currentIndex]
    if (!item) return

    this.imageTarget.src = item.url
    this.imageTarget.alt = item.title
    this.titleTarget.textContent = item.title
    this.metaTarget.textContent = item.meta
  }
}

class RichTextController extends Controller {
  static targets = ["editor", "fileInput", "input", "status"]

  connect() {
    this.editorTarget.innerHTML = this.inputTarget.value || ""
    this.form = this.element.closest("form")
    this.boundSync = this.sync.bind(this)
    this.boundRememberImage = this.rememberImage.bind(this)
    this.form?.addEventListener("submit", this.boundSync)
    this.editorTarget.addEventListener("click", this.boundRememberImage)
  }

  disconnect() {
    this.form?.removeEventListener("submit", this.boundSync)
    this.editorTarget.removeEventListener("click", this.boundRememberImage)
  }

  format(event) {
    event.preventDefault()

    const command = event.params.command
    const value = this.blockValue(event.params.value)

    this.editorTarget.focus()
    document.execCommand(command, false, value)
    this.sync()
  }

  link(event) {
    event.preventDefault()

    const currentSelection = window.getSelection()?.toString()
    const url = window.prompt("URL", "https://")
    if (!url || url === "https://") return

    if (!currentSelection) {
      document.execCommand("insertHTML", false, `<a href="${this.escapeAttribute(url)}">${this.escapeHtml(url)}</a>`)
    } else {
      document.execCommand("createLink", false, url)
    }

    this.editorTarget.querySelectorAll("a").forEach((link) => {
      link.setAttribute("target", "_blank")
      link.setAttribute("rel", "noreferrer")
    })
    this.sync()
  }

  chooseImage(event) {
    event.preventDefault()

    this.fileInputTarget.click()
  }

  async uploadImage() {
    const file = this.fileInputTarget.files[0]
    if (!file) return

    if (!file.type.startsWith("image/")) {
      this.setStatus("只能上传图片文件。", true)
      this.fileInputTarget.value = ""
      return
    }

    const formData = new FormData()
    formData.append("image", file)
    this.setStatus("图片上传中...")

    try {
      const response = await fetch("/admin/uploads", {
        method: "POST",
        headers: {
          "X-CSRF-Token": this.csrfToken(),
          "Accept": "application/json"
        },
        body: formData
      })
      const payload = await response.json()

      if (!response.ok) {
        throw new Error(payload.error || "图片上传失败。")
      }

      this.insertImage(payload.url, payload.alt || payload.filename || file.name)
      this.setStatus("图片已插入。")
    } catch (error) {
      this.setStatus(error.message || "图片上传失败。", true)
    } finally {
      this.fileInputTarget.value = ""
    }
  }

  setImageSize(event) {
    event.preventDefault()

    const figure = this.currentFigure()
    if (!figure) {
      this.setStatus("请先点击正文中的图片。", true)
      return
    }

    const size = event.params.size || "full"
    this.applyImageSize(figure, size)
    this.setStatus(`图片尺寸已调整为 ${this.imageSizeLabel(size)}。`)
    this.sync()
  }

  clear(event) {
    event.preventDefault()

    this.editorTarget.focus()
    if (window.getSelection()?.toString()) {
      document.execCommand("removeFormat", false, null)
    } else {
      this.editorTarget.innerHTML = this.textToParagraphHtml(this.editorTarget.textContent)
    }
    this.sync()
  }

  handlePaste(event) {
    event.preventDefault()

    const text = event.clipboardData.getData("text/plain")
    document.execCommand("insertHTML", false, this.textToParagraphHtml(text))
    this.sync()
  }

  sync() {
    const html = this.cleanEditorHtml().trim()
    this.inputTarget.value = this.isBlankHtml(html) ? "" : html
  }

  cleanEditorHtml() {
    const clone = this.editorTarget.cloneNode(true)
    clone.querySelectorAll("figure.is-selected").forEach((figure) => {
      figure.classList.remove("is-selected")
      if (!figure.getAttribute("class")) {
        figure.removeAttribute("class")
      }
    })
    return clone.innerHTML
  }

  insertImage(url, alt) {
    this.editorTarget.focus()
    const safeUrl = this.escapeAttribute(url)
    const safeAlt = this.escapeAttribute(alt)
    const figure = [
      `<figure class="post-image--full">`,
      `<img src="${safeUrl}" alt="${safeAlt}" loading="lazy">`,
      `<figcaption>${this.escapeHtml(alt)}</figcaption>`,
      "</figure>",
      "<p><br></p>"
    ].join("")

    document.execCommand("insertHTML", false, figure)
    this.sync()
  }

  rememberImage(event) {
    const image = event.target.closest("img")
    if (!image || !this.editorTarget.contains(image)) return

    this.selectedFigure = image.closest("figure")
    this.editorTarget.querySelectorAll("figure.is-selected").forEach((figure) => {
      figure.classList.remove("is-selected")
    })
    this.selectedFigure?.classList.add("is-selected")
    this.setStatus("已选中图片，可调整尺寸。")
  }

  currentFigure() {
    if (this.selectedFigure && this.editorTarget.contains(this.selectedFigure)) {
      return this.selectedFigure
    }

    const selectionNode = window.getSelection()?.anchorNode
    const element = selectionNode?.nodeType === Node.ELEMENT_NODE ? selectionNode : selectionNode?.parentElement
    return element?.closest?.("figure")
  }

  applyImageSize(figure, size) {
    figure.classList.remove("post-image--small", "post-image--medium", "post-image--full")
    figure.classList.add(`post-image--${size}`)
  }

  imageSizeLabel(size) {
    return {
      small: "小图",
      medium: "中图",
      full: "全宽"
    }[size] || "全宽"
  }

  blockValue(value) {
    return value ? `<${value}>` : null
  }

  textToParagraphHtml(text) {
    return text
      .trim()
      .split(/\n{2,}/)
      .filter((paragraph) => paragraph.trim().length > 0)
      .map((paragraph) => `<p>${this.escapeHtml(paragraph).replace(/\n/g, "<br>")}</p>`)
      .join("")
  }

  isBlankHtml(html) {
    const text = this.editorTarget.textContent.replace(/\u00a0/g, " ").trim()
    return !text && html.replace(/<br\s*\/?>/gi, "").replace(/&nbsp;/gi, "").trim() === ""
  }

  escapeHtml(value) {
    return value.replace(/[&<>"']/g, (character) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      "\"": "&quot;",
      "'": "&#39;"
    }[character]))
  }

  escapeAttribute(value) {
    return this.escapeHtml(value).replace(/`/g, "&#96;")
  }

  csrfToken() {
    return document.querySelector("meta[name='csrf-token']")?.content || ""
  }

  setStatus(message, isError = false) {
    if (!this.hasStatusTarget) return

    this.statusTarget.textContent = message
    this.statusTarget.classList.toggle("is-error", isError)
  }
}

class ImageResizeController extends Controller {
  static targets = [
    "dropzone",
    "fileInput",
    "fitSelect",
    "widthInput",
    "heightInput",
    "unitSelect",
    "resolutionInput",
    "lockInput",
    "resampleInput",
    "originalImage",
    "canvas",
    "status",
    "originalDimensions",
    "resizedDimensions",
    "scaleValue",
    "resultSummary",
    "resultSizeDetail",
    "originalFileSize",
    "estimatedFileSize",
    "estimatedPngSize",
    "estimatedWebpSize",
    "lastExportFormat",
    "originalBadge",
    "resizedBadge",
    "preset",
    "resizeControl"
  ]

  connect() {
    this.image = null
    this.originalFile = null
    this.originalUrl = null
    this.dragDepth = 0
    this.currentUnit = "px"
    this.ppi = 72
    this.currentPixels = { width: 1200, height: 800 }
    this.estimateToken = 0
    this.renderState()
    this.resetOutputState()
    this.updateDimensionInputs()
  }

  disconnect() {
    if (this.originalUrl) URL.revokeObjectURL(this.originalUrl)
  }

  browse(event) {
    event.preventDefault()
    this.fileInputTarget.click()
  }

  dragEnter(event) {
    event.preventDefault()
    this.dragDepth += 1
    this.dropzoneTarget.classList.add("is-dragging")
  }

  dragOver(event) {
    event.preventDefault()
    event.dataTransfer.dropEffect = "copy"
    this.dropzoneTarget.classList.add("is-dragging")
  }

  dragLeave(event) {
    event.preventDefault()
    this.dragDepth = Math.max(0, this.dragDepth - 1)

    if (this.dragDepth === 0) {
      this.dropzoneTarget.classList.remove("is-dragging")
    }
  }

  drop(event) {
    event.preventDefault()
    this.dragDepth = 0
    this.dropzoneTarget.classList.remove("is-dragging")

    const file = Array.from(event.dataTransfer.files || []).find((item) => item.type.startsWith("image/"))
    if (!file) {
      this.setStatus("Please drop an image file.", true)
      return
    }

    this.loadFile(file)
  }

  loadFromInput() {
    const file = this.fileInputTarget.files[0]
    this.fileInputTarget.value = ""

    if (!file) return

    this.loadFile(file)
  }

  async loadFile(file) {
    if (!file.type.startsWith("image/")) {
      this.setStatus("Only image files are supported here.", true)
      return
    }

    const url = URL.createObjectURL(file)
    this.setStatus("Loading image...")

    try {
      const image = await this.loadImage(url)

      if (this.originalUrl) URL.revokeObjectURL(this.originalUrl)

      this.originalUrl = url
      this.originalFile = file
      this.image = image
      this.aspectRatio = image.naturalWidth / image.naturalHeight
      this.currentUnit = "px"
      this.ppi = 72
      this.originalImageTarget.src = url
      this.originalImageTarget.alt = file.name
      this.unitSelectTarget.value = this.currentUnit
      this.resolutionInputTarget.value = this.ppi
      this.fitSelectTarget.value = "original"

      this.setPixelDimensions(image.naturalWidth, image.naturalHeight, "original")
      this.activatePreset("original")
      this.resetOutputState()
      this.renderCanvas()
      this.renderState()
      this.setStatus(`Loaded ${file.name}. Adjust the size, then export PNG or WebP.`)
    } catch (error) {
      URL.revokeObjectURL(url)
      this.setStatus("This image could not be read by the browser.", true)
    }
  }

  resizeFromWidth() {
    if (!this.hasImage()) return

    const width = this.pixelsFromDisplayValue(this.widthInputTarget.value, this.currentPixels.width)
    const height = this.lockInputTarget.checked ?
      Math.max(1, Math.round(width / this.aspectRatio)) :
      this.pixelsFromDisplayValue(this.heightInputTarget.value, this.currentPixels.height)

    this.setPixelDimensions(width, height, "custom")
    this.afterDimensionChange()
  }

  resizeFromHeight() {
    if (!this.hasImage()) return

    const height = this.pixelsFromDisplayValue(this.heightInputTarget.value, this.currentPixels.height)
    const width = this.lockInputTarget.checked ?
      Math.max(1, Math.round(height * this.aspectRatio)) :
      this.pixelsFromDisplayValue(this.widthInputTarget.value, this.currentPixels.width)

    this.setPixelDimensions(width, height, "custom")
    this.afterDimensionChange()
  }

  toggleLock() {
    if (!this.hasImage()) return

    if (this.lockInputTarget.checked) {
      const width = this.pixelsFromDisplayValue(this.widthInputTarget.value, this.currentPixels.width)
      this.setPixelDimensions(width, Math.max(1, Math.round(width / this.aspectRatio)), "custom")
    }

    this.afterDimensionChange()
  }

  toggleResample() {
    if (!this.hasImage()) return

    this.resetOutputState()
    this.renderCanvas()
    this.setStatus(this.resampleInputTarget.checked ? "Resampling enabled." : "Resampling disabled.")
  }

  changeUnit() {
    if (!this.hasImage()) return

    this.currentUnit = this.unitSelectTarget.value
    this.updateDimensionInputs()
    this.renderCanvas()
  }

  changeResolution() {
    if (!this.hasImage()) return

    const previousUnit = this.currentUnit
    const currentWidthValue = Number.parseFloat(this.widthInputTarget.value)
    const currentHeightValue = Number.parseFloat(this.heightInputTarget.value)
    this.ppi = this.normalizedResolution(this.resolutionInputTarget.value)
    this.resolutionInputTarget.value = this.ppi

    if (previousUnit !== "px" && Number.isFinite(currentWidthValue) && Number.isFinite(currentHeightValue)) {
      const width = this.pixelsFromDisplayValue(currentWidthValue, this.currentPixels.width)
      const height = this.lockInputTarget.checked ?
        Math.max(1, Math.round(width / this.aspectRatio)) :
        this.pixelsFromDisplayValue(currentHeightValue, this.currentPixels.height)
      this.setPixelDimensions(width, height, "custom")
    } else {
      this.updateDimensionInputs()
    }

    this.afterDimensionChange()
  }

  applyFit() {
    if (!this.hasImage()) return

    this.applyPresetValue(this.fitSelectTarget.value)
  }

  applyPreset(event) {
    if (!this.hasImage()) {
      this.setStatus("Upload an image first.", true)
      return
    }

    this.applyPresetValue(event.params.preset, event.currentTarget.textContent.trim())
  }

  applyPresetValue(preset, label = null) {
    if (preset === "custom") {
      this.setStatus("Custom size is active.")
      return
    }

    let width = this.image.naturalWidth
    let height = this.image.naturalHeight

    if (preset === "double") {
      width = this.image.naturalWidth * 2
      height = this.image.naturalHeight * 2
    }

    if (preset === "half") {
      width = Math.max(1, Math.round(this.image.naturalWidth / 2))
      height = Math.max(1, Math.round(this.image.naturalHeight / 2))
    }

    this.setPixelDimensions(width, height, preset)
    this.fitSelectTarget.value = preset || "custom"
    this.activatePreset(preset)
    this.resetOutputState()
    this.renderCanvas()
    this.setStatus(label ? `Preset ${label} applied.` : "Image size updated.")
  }

  async export(event) {
    if (!this.hasImage()) {
      this.setStatus("Upload an image first.", true)
      return
    }

    const format = (event.params.format || "png").toLowerCase()
    const mimeType = format === "webp" ? "image/webp" : "image/png"

    this.setStatus(`Preparing ${format.toUpperCase()}...`)

    try {
      const blob = await this.canvasToBlob(mimeType, format === "webp" ? 0.92 : undefined)
      if (format === "webp" && blob.type !== "image/webp") {
        throw new Error("This browser could not export WebP from canvas.")
      }

      const filename = this.downloadName(format)
      const url = URL.createObjectURL(blob)
      const link = document.createElement("a")
      link.href = url
      link.download = filename
      link.click()
      window.setTimeout(() => URL.revokeObjectURL(url), 1000)

      this.lastExportFormatTarget.textContent = `${format.toUpperCase()} · ${filename} · ${this.humanFileSize(blob.size)}`
      this.setStatus(`${filename} downloaded.`)
    } catch (error) {
      this.setStatus(error.message || "Export failed.", true)
    }
  }

  renderState() {
    const ready = this.hasImage()

    this.resizeControlTargets.forEach((element) => {
      element.disabled = !ready
    })
  }

  renderCanvas() {
    if (!this.hasImage()) return

    const { width, height } = this.currentDimensions()
    const context = this.canvasTarget.getContext("2d")

    this.canvasTarget.width = width
    this.canvasTarget.height = height
    context.clearRect(0, 0, width, height)
    context.imageSmoothingEnabled = this.resampleInputTarget.checked
    if (context.imageSmoothingEnabled) context.imageSmoothingQuality = "high"
    context.drawImage(this.image, 0, 0, width, height)

    this.originalDimensionsTarget.textContent = `${this.image.naturalWidth} x ${this.image.naturalHeight} px`
    this.resizedDimensionsTarget.textContent = this.dimensionSummary(width, height)
    this.scaleValueTarget.textContent = this.scaleLabel(width, height)
    this.resultSummaryTarget.textContent = this.scaleLabel(width, height)
    this.originalFileSizeTarget.textContent = this.humanFileSize(this.originalFile?.size || 0)
    this.originalBadgeTarget.textContent = `${this.image.naturalWidth} x ${this.image.naturalHeight}`
    this.resizedBadgeTarget.textContent = `${width} x ${height}`
    this.estimateOutputSizes()
  }

  afterDimensionChange() {
    this.activatePreset(this.matchingPreset())
    this.fitSelectTarget.value = this.matchingPreset() || "custom"
    this.resetOutputState()
    this.renderCanvas()
  }

  matchingPreset() {
    if (!this.hasImage()) return null

    const { width, height } = this.currentDimensions()
    const original = width === this.image.naturalWidth && height === this.image.naturalHeight
    const doubled = width === this.image.naturalWidth * 2 && height === this.image.naturalHeight * 2
    const halved = width === Math.max(1, Math.round(this.image.naturalWidth / 2)) &&
      height === Math.max(1, Math.round(this.image.naturalHeight / 2))

    if (original) return "original"
    if (doubled) return "double"
    if (halved) return "half"

    return null
  }

  activatePreset(name) {
    this.presetTargets.forEach((button) => {
      button.classList.toggle("is-active", button.dataset.imageResizePresetParam === name)
    })
  }

  hasImage() {
    return Boolean(this.image)
  }

  currentDimensions() {
    return {
      width: this.currentPixels.width,
      height: this.currentPixels.height
    }
  }

  setPixelDimensions(width, height, preset = "custom") {
    this.currentPixels = {
      width: this.normalizedDimension(width, this.image?.naturalWidth || 1200),
      height: this.normalizedDimension(height, this.image?.naturalHeight || 800)
    }
    this.updateDimensionInputs()
    this.fitSelectTarget.value = preset || "custom"
  }

  normalizedDimension(value, fallback) {
    const parsed = Number.parseInt(value, 10)
    if (!Number.isFinite(parsed) || parsed < 1) return fallback

    return Math.min(parsed, 12000)
  }

  normalizedResolution(value) {
    const parsed = Number.parseInt(value, 10)
    if (!Number.isFinite(parsed) || parsed < 1) return 72

    return Math.min(parsed, 1200)
  }

  resetOutputState() {
    if (this.hasEstimatedFileSizeTarget) this.estimatedFileSizeTarget.textContent = "--"
    if (this.hasEstimatedPngSizeTarget) this.estimatedPngSizeTarget.textContent = "--"
    if (this.hasEstimatedWebpSizeTarget) this.estimatedWebpSizeTarget.textContent = "--"
    if (this.hasResultSizeDetailTarget) this.resultSizeDetailTarget.textContent = "上传图片后显示预计导出体积。"
    this.lastExportFormatTarget.textContent = "Not exported yet"
  }

  updateDimensionInputs() {
    if (!this.hasWidthInputTarget || !this.hasHeightInputTarget) return

    const width = this.displayValueFromPixels(this.currentPixels.width)
    const height = this.displayValueFromPixels(this.currentPixels.height)
    const step = this.currentUnit === "px" ? "1" : "0.01"

    this.widthInputTarget.step = step
    this.heightInputTarget.step = step
    this.widthInputTarget.value = this.formatDisplayDimension(width)
    this.heightInputTarget.value = this.formatDisplayDimension(height)
  }

  displayValueFromPixels(pixels) {
    if (this.currentUnit === "in") return pixels / this.ppi
    if (this.currentUnit === "cm") return (pixels / this.ppi) * 2.54

    return pixels
  }

  pixelsFromDisplayValue(value, fallback) {
    const parsed = Number.parseFloat(value)
    if (!Number.isFinite(parsed) || parsed <= 0) return fallback

    if (this.currentUnit === "in") return this.normalizedDimension(Math.round(parsed * this.ppi), fallback)
    if (this.currentUnit === "cm") return this.normalizedDimension(Math.round((parsed / 2.54) * this.ppi), fallback)

    return this.normalizedDimension(Math.round(parsed), fallback)
  }

  formatDisplayDimension(value) {
    if (this.currentUnit === "px") return String(Math.round(value))

    return String(Math.round(value * 100) / 100)
  }

  dimensionSummary(width, height) {
    const unitSummary = this.currentUnit === "px" ?
      "" :
      ` · ${this.formatDisplayDimension(this.displayValueFromPixels(width))} x ${this.formatDisplayDimension(this.displayValueFromPixels(height))} ${this.currentUnit}`

    return `${width} x ${height} px${unitSummary} · ${this.ppi} ppi`
  }

  async estimateOutputSizes() {
    if (!this.hasImage()) return

    const token = this.estimateToken + 1
    this.estimateToken = token
    this.estimatedFileSizeTarget.textContent = "Calculating..."
    this.estimatedPngSizeTarget.textContent = "Calculating..."
    this.estimatedWebpSizeTarget.textContent = "Calculating..."

    try {
      const [pngBlob, webpBlob] = await Promise.all([
        this.canvasToBlob("image/png"),
        this.canvasToBlob("image/webp", 0.92)
      ])
      if (token !== this.estimateToken) return

      const pngComparison = this.sizeComparison(pngBlob.size)
      const webpComparison = webpBlob.type === "image/webp" ?
        this.sizeComparison(webpBlob.size) :
        "This browser does not support WebP export."

      this.resultSizeDetailTarget.textContent = `PNG ${pngComparison}`
      this.estimatedFileSizeTarget.textContent = webpBlob.type === "image/webp" ?
        `PNG ${pngComparison} · WebP ${webpComparison}` :
        `PNG ${pngComparison}`
      this.estimatedPngSizeTarget.textContent = pngComparison
      this.estimatedWebpSizeTarget.textContent = webpComparison
    } catch (error) {
      if (token !== this.estimateToken) return

      this.estimatedFileSizeTarget.textContent = "Unable to estimate."
      this.estimatedPngSizeTarget.textContent = "Unable to estimate."
      this.estimatedWebpSizeTarget.textContent = "Unable to estimate."
      this.resultSizeDetailTarget.textContent = "Unable to estimate export size."
    }
  }

  sizeComparison(size) {
    const originalSize = this.originalFile?.size || 0
    const percent = originalSize > 0 ? Math.round((size / originalSize) * 100) : null
    const suffix = percent === null ? "" : `（原图的 ${percent}%）`

    return `${this.humanFileSize(size)}${suffix}`
  }

  loadImage(url) {
    return new Promise((resolve, reject) => {
      const image = new Image()
      image.onload = () => resolve(image)
      image.onerror = () => reject(new Error("Image load failed."))
      image.src = url
    })
  }

  canvasToBlob(type, quality) {
    return new Promise((resolve, reject) => {
      this.canvasTarget.toBlob((blob) => {
        if (blob) {
          resolve(blob)
        } else {
          reject(new Error("Canvas export is not available in this browser."))
        }
      }, type, quality)
    })
  }

  downloadName(format) {
    const extension = format === "webp" ? "webp" : "png"
    const baseName = (this.originalFile?.name || "image").replace(/\.[^.]+$/, "")
    const { width, height } = this.currentDimensions()

    return `${baseName}-${width}x${height}.${extension}`
  }

  scaleLabel(width, height) {
    const widthScale = Math.round((width / this.image.naturalWidth) * 100)
    const heightScale = Math.round((height / this.image.naturalHeight) * 100)

    return widthScale === heightScale ? `${widthScale}%` : `${widthScale}% x ${heightScale}%`
  }

  humanFileSize(size) {
    if (!size) return "--"

    const units = ["B", "KB", "MB", "GB"]
    let value = size
    let unitIndex = 0

    while (value >= 1024 && unitIndex < units.length - 1) {
      value /= 1024
      unitIndex += 1
    }

    const precision = unitIndex === 0 ? 0 : value >= 10 ? 1 : 2
    return `${value.toFixed(precision)} ${units[unitIndex]}`
  }

  setStatus(message, isError = false) {
    if (!this.hasStatusTarget) return

    this.statusTarget.textContent = message
    this.statusTarget.classList.toggle("is-error", isError)
  }
}

window.Stimulus = Application.start()
window.Stimulus.register("theme", ThemeController)
window.Stimulus.register("arcade", ArcadeController)
window.Stimulus.register("gallery", GalleryController)
window.Stimulus.register("rich-text", RichTextController)
window.Stimulus.register("image-resize", ImageResizeController)
